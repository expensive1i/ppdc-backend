NODE_ENV=development
PORT=4000
API_PREFIX=/api
DATABASE_URL=postgresql://username:password@endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://username:password@endpoint.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
